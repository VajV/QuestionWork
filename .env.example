# Example environment variables for QuestionWork
# Copy to `.env` and fill values for your environment.

# Application
APP_NAME=QuestionWork
APP_ENV=development
DEBUG=true

# Security
# Set a strong secret in production (at least 32 bytes)
SECRET_KEY=

# Server
HOST=127.0.0.1
PORT=8000

# Database (Postgres)
# Example: postgresql://user:pass@localhost:5432/questionwork
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/questionwork

# Redis for rate-limiting / sessions
REDIS_URL=redis://localhost:6379

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Frontend
FRONTEND_URL=http://localhost:3000

# Optional third-party keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct
# ============================================================
# QuestionWork Environment Variables Example
# Скопируйте этот файл в .env и заполните своими значениями.
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
APP_NAME=QuestionWork
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-in-production

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
HOST=127.0.0.1
PORT=8000

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=questionwork
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/questionwork

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# JWT
# ------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ------------------------------------------------------------
# CORS / Frontend
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ------------------------------------------------------------
# OpenRouter (optional)
# ------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct
