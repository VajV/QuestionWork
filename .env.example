# ============================================================
# QuestionWork Environment Variables Example
# Copy to `.env` and fill values for your environment.
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
APP_NAME=QuestionWork
APP_ENV=development
DEBUG=true

# ------------------------------------------------------------
# Security
# Set a strong random secret in production (at least 32 bytes).
# Leave empty here — the app will refuse to start with a blank key.
# ------------------------------------------------------------
SECRET_KEY=

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
HOST=127.0.0.1
PORT=8001

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=questionwork
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/questionwork

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# JWT
# ------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=5

# ------------------------------------------------------------
# Cookies (set to true in production behind HTTPS)
# ------------------------------------------------------------
COOKIE_SECURE=true
ADMIN_TOTP_REQUIRED=true

# ------------------------------------------------------------
# CORS / Frontend
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001/api/v1

# ------------------------------------------------------------
# OpenRouter (optional)
# ------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct
