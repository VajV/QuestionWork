# QuestionWork Backend Configuration

# Application
APP_NAME=QuestionWork
APP_ENV=development          # development | staging | production
DEBUG=True                   # set False in production
SECRET_KEY=your-secret-key-here   # generate: python -c "import secrets; print(secrets.token_hex(32))"

# Server
HOST=127.0.0.1
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/questionwork

# Redis
REDIS_URL=redis://localhost:6379

# JWT Settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15       # access token TTL in minutes

# Refresh Token Settings
REFRESH_TOKEN_EXPIRE_DAYS=7  # refresh token TTL in days

# Cookie Security (defaults to True in code; set False for local dev without HTTPS)
COOKIE_SECURE=false          # Local development only — disable HTTPS cookie requirement
COOKIE_SAMESITE=lax          # lax | strict | none

# CORS (Frontend URL)
FRONTEND_URL=http://localhost:3000

# Observability — Sentry (leave empty to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Observability — OpenTelemetry (leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=questionwork-backend
OTEL_SAMPLE_RATE=0.1

# OpenRouter API (for AI quest review — optional)
OPENROUTER_API_KEY=your-api-key-here
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct
