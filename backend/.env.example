# QuestionWork Backend Configuration

# Application
APP_NAME=QuestionWork
APP_ENV=development          # development | staging | production
DEBUG=True                   # set False in production
SECRET_KEY=                       # REQUIRED — generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Server
HOST=127.0.0.1
PORT=8001

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/questionwork

# Redis
# Password must match REDIS_PASSWORD in docker-compose.dev.yml (default: changeme)
REDIS_URL=redis://:changeme@localhost:6379/0

# JWT Settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=5        # access token TTL in minutes (short-lived; refresh tokens handle session)

# Refresh Token Settings
REFRESH_TOKEN_EXPIRE_DAYS=7  # refresh token TTL in days

# Cookie Security — WARNING: production MUST use True (HTTPS required)
COOKIE_SECURE=true           # set false ONLY for local HTTP dev without HTTPS
COOKIE_SAMESITE=lax          # lax | strict | none

# CORS (Frontend URL)
FRONTEND_URL=http://localhost:3000

# Admin Security
# Comma-separated IP addresses allowed for admin endpoints. Required in production.
# ADMIN_IP_ALLOWLIST=10.0.0.1,192.168.1.100
# Require TOTP (2FA) for all admin requests. WARNING: production MUST use True.
ADMIN_TOTP_REQUIRED=true     # set false ONLY for local dev without TOTP setup
# Separate encryption key for TOTP secrets. Required when ADMIN_TOTP_REQUIRED=True.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# TOTP_ENCRYPTION_KEY=

# Observability — Sentry (leave empty to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Observability — OpenTelemetry (leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=questionwork-backend
OTEL_SAMPLE_RATE=0.1

# OpenRouter API (for AI quest review — optional)
OPENROUTER_API_KEY=your-api-key-here
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct

# Email / SMTP (all optional — set to enable transactional emails)
EMAILS_ENABLED=false              # master switch: true to enable email sending
SMTP_HOST=                        # e.g. smtp.sendgrid.net, smtp.yandex.ru
SMTP_PORT=587                     # 587 for STARTTLS, 465 for implicit SSL
SMTP_USER=                        # SMTP login / API key username
SMTP_PASSWORD=                    # SMTP password / API key
SMTP_FROM=noreply@questionwork.com  # envelope sender
SMTP_TLS=true                     # true = STARTTLS (port 587), false = implicit SSL (port 465)
